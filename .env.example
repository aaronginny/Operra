# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_ops_assistant

# ── OpenAI (optional — falls back to rule-based extraction) ──
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ── WhatsApp webhook verification token ──────────────────────
WHATSAPP_VERIFY_TOKEN=your-verify-token-here

# ── Twilio WhatsApp ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Email (SMTP / Gmail) ─────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# ── Founder Notifications ─────────────────────────────────
FOUNDER_PHONE=+919876543210
FOUNDER_EMAIL=founder@example.com

# ── Daily Report ──────────────────────────────────────────
DAILY_REPORT_TIME=09:00
